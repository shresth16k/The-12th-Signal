# The 12th Signal - Backend Environment Configuration Template
# Copy this file to a new file named '.env' and fill in your values.
# Do not commit the actual '.env' file to the repository.

# Anthropic Claude API Key for GenAI clustering, agent negotiation, and chat assistant
# Format: sk-ant-api03-...
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Operations security token for accessing admin and PA system endpoints (required)
# Format: A strong random secret string
OPS_TOKEN=your_ops_token_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173

